# ==============================================================================
# OS & IDE SPECIFIC
# ==============================================================================

# macOS system files (Thumbnails, desktop layout configurations)
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# VS Code workspaces, settings, and local history logs
.vscode/*
!.vscode/extensions.json
.history/
*.code-workspace

# Other common IDE/Editor directories and crash dumps
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


# ==============================================================================
# DIAGNOSTICS & LOGS
# ==============================================================================

# System logs and package manager debug dumps
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ==============================================================================
# RUST & CARGO (Backend)
# ==============================================================================

# Compilation artifacts, dependency builds, and debug/release binaries
/target/

# Backup files generated by Cargo commands
**/*.rs.bk

# Log files generated by Rust or Cargo crashes
cargo-timing.bin


# ==============================================================================
# NODE / NODE_MODULES / FRONTEND (Tauri Webview)
# ==============================================================================

# Third-party frontend dependencies and package manager caches
node_modules/
.npm
.eslintcache
.stylelintcache

# Frontend build outputs and distribution bundles
dist/
dist-ssr/
build/
out/


# ==============================================================================
# TAURI (Desktop Framework)
# ==============================================================================

# Tauri-specific build artifacts and automatically generated app bundles
src-tauri/target/


# ==============================================================================
# DATABASE (SQLite / Rusqlite)
# ==============================================================================

# Local SQLite database files, journals, and temporary write-ahead logs
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite3-journal
*.wal
*.shm


# ==============================================================================
# ENVIRONMENT VARIABLES & CREDENTIALS
# ==============================================================================

# Private API keys, local environment configs, and secret tokens
.env
.env.local
.env.*.local
*.pem
*.local


# ==============================================================================
# USER & AI SPECIFIC (Personal Project Files)
# ==============================================================================
# Use this section for files you want to keep locally for tracking progress, 
# managing your AI workflows, and planning, without pushing them to GitHub.

# AI context handoffs, roadmap timelines, and local markdown planning documentation
handoffs/
md_files/


# Add any specific custom local files or directories below:
# my-private-notes/